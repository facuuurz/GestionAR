generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Enum para Roles
enum Role {
  SUPERADMIN
  ADMIN
  EMPLEADO
}

// Modelo de Usuario
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  username  String   @unique
  passwordHash String
  profilePicture String? @db.Text
  role      Role     @default(EMPLEADO)
  
  // Perfil Admin
  phone      String?
  address    String?
  localName  String?

  // Perfil Empleado
  dni        String?
  cuit       String?
  lastActive DateTime?
  seniorityDate DateTime? @default(now())

  ventas    Venta[]

  passwordHistory PasswordHistory[]
  notifications   Notification[]

  // Self-relation: Un Admin/SuperAdmin puede crear a otros usuarios
  createdById Int?
  createdBy   User?  @relation("UserCreator", fields: [createdById], references: [id])
  createdUsers User[] @relation("UserCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// Historial de contraseñas (últimas 5) para evitar reutilización
model PasswordHistory {
  id           Int      @id @default(autoincrement())
  userId       Int
  passwordHash String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_history")
}

// Modelo Notificaciones
model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   // 'USER_CREATED', 'USER_DELETED', 'STOCK_LOW', 'STOCK_NONE', 'PROMO_ACTIVED', 'PROMO_ENDED'
  message   String
  linkUrl   String?
  isRead    Boolean  @default(false)
  
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("notifications")
}

// Modelo Producto
model Producto {
  id               Int       @id @default(autoincrement()) @map("id_producto")
  nombre           String    @map("nombre_producto")
  codigoBarra      String?   @map("codigo_barra")
  descripcion      String?   @map("descripcion")
  tipo             String?   @map("tipo_producto")
  proveedor        String?   @map("codigo_proveedor")
  stock            Int       @default(0) @map("stock_inicial")
  precio           Decimal   @default(0.00) @map("precio_unitario") @db.Decimal(10, 2)
  fechaVencimiento DateTime? @map("fecha_vencimiento") @db.Date

  esPorPeso Boolean @default(false)

  promociones PromocionProducto[]

  detallesVenta DetalleVenta[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([codigoBarra, fechaVencimiento])
  @@map("productos")
}

// Modelo Categoria
model Categoria {
  id     Int    @id @default(autoincrement())
  nombre String @unique
}

// Modelo Proveedor
model Proveedor {
  id          Int      @id @default(autoincrement())
  codigo      String   @unique
  razonSocial String
  contacto    String?
  telefono    String?
  email       String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("proveedores")
}

// --- MODIFICADO: CUENTA CORRIENTE ---
model Cuenta_corriente {
  id        Int     @id @default(autoincrement())
  nombre    String  @map("razon_social")
  cuit      String? @unique
  telefono  String?
  email     String?
  direccion String?
  ciudad    String?

  saldo  Decimal    @default(0.00) @db.Decimal(10, 2)
  estado String     @default("Al Día")
  saldoNegativoDesde DateTime?

  movimientos Movimiento[]

  ventas Venta[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Cuentas_corrientes")
}

// --- ✅ NUEVO MODELO: MOVIMIENTO ---
model Movimiento {
  id          Int      @id @default(autoincrement())
  fecha       DateTime @default(now())
  descripcion String
  monto       Decimal  @db.Decimal(10, 2) // Guardamos con precisión
  tipo        String // "CREDITO" o "DEBITO"

  // Relación con la cuenta corriente
  cuentaCorrienteId Int
  cuenta            Cuenta_corriente @relation(fields: [cuentaCorrienteId], references: [id], onDelete: Cascade)

  @@map("movimientos")
}

// Modelo Promocion
model Promocion {
  id          Int      @id @default(autoincrement())
  nombre      String
  descripcion String
  precio      Decimal
  activo      Boolean  @default(true)
  fechaInicio DateTime
  fechaFin    DateTime

  items PromocionProducto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("promociones")
}

// Modelo Tabla Intermedia Promocion-Producto
model PromocionProducto {
  promocionId Int
  productoId  Int
  cantidad    Int     @default(1)
  precioPromocional Decimal @default(0.00) @db.Decimal(10, 2)

  promocion Promocion @relation(fields: [promocionId], references: [id], onDelete: Cascade)
  // CAMBIA ESTA LÍNEA:
  producto  Producto  @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@id([promocionId, productoId])
  @@map("promocion_productos")
}

model Venta {
  id    Int      @id @default(autoincrement())
  fecha DateTime @default(now())
  total Decimal  @db.Decimal(10, 2)

  // Relación opcional: Si es null, es Consumidor Final. Si tiene ID, es un cliente con Cuenta.
  cuentaCorrienteId Int?
  cuenta            Cuenta_corriente? @relation(fields: [cuentaCorrienteId], references: [id])

  // Relación opcional con el Usuario (Vendedor)
  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  detalles DetalleVenta[]

  @@map("ventas")
}

model DetalleVenta {
  id         Int     @id @default(autoincrement())
  ventaId    Int
  productoId Int
  cantidad   Decimal @db.Decimal(10, 3) // Decimal para soportar peso (ej: 1.5 kg)
  precioUnit Decimal @db.Decimal(10, 2) // Precio al momento de la venta
  subtotal   Decimal @db.Decimal(10, 2)

  venta    Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@map("detalle_ventas")
}
