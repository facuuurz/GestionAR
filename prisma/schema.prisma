generator client {
  provider = "prisma-client"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // NOTA: Para hacer migraciones (npx prisma migrate), Prisma necesita la URL aquí.
  // Si usas un setup personalizado, asegúrate de que el comando migrate sepa dónde conectarse.
}

// Modelo de Usuario (sin cambios)
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Modelo Producto corregido
model Producto {
  id          Int      @id @default(autoincrement()) @map("id_producto")
  nombre      String   @map("nombre_producto")
  
  // ✅ SOLUCIÓN: Cambiado de Int a String para soportar códigos largos y ceros iniciales
  codigoBarra String?  @unique @map("codigo_barra") 
  
  // ✅ NUEVO CAMPO: Descripción (Opcional)
  descripcion   String?  @map("descripcion")

  tipo        String?  @map("tipo_producto")
  proveedor   String?  @map("codigo_proveedor")
  
  stock       Int      @default(0) @map("stock_inicial")
  
  // Decimal es perfecto para dinero (evita errores de redondeo de float)
  precio      Decimal  @default(0.00) @db.Decimal(10, 2) @map("precio_unitario")

  promociones PromocionProducto[]

  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("productos")
}

//para los tipos de productos
model Categoria {
  id    Int    @id @default(autoincrement())
  nombre String @unique // @unique evita duplicados
}

model Proveedor {
  id          Int      @id @default(autoincrement())
  codigo      String   @unique // Ej: PROV-1024
  razonSocial String
  contacto    String?  // Ej: Roberto Gómez
  telefono    String?
  email       String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("proveedores")
}

model Cuenta_corriente {
  id              Int      @id @default(autoincrement())
  nombre          String   @map("razon_social")
  cuit            String?  @unique
  telefono        String?
  email           String?
  direccion       String?
  ciudad    String?
  
  saldo           Decimal  @default(0.00) @db.Decimal(10, 2) 
  estado          String   @default("Al Día")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("Cuentas_corrientes") 
}

model Promocion {
  id          Int      @id @default(autoincrement())
  nombre      String
  descripcion String
  precio      Float    // Precio promocional
  fechaInicio DateTime
  fechaFin    DateTime

  productos   PromocionProducto[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PromocionProducto {
  promocionId Int
  productoId  Int
  cantidad    Int       @default(1)

  promocion   Promocion @relation(fields: [promocionId], references: [id], onDelete: Cascade)
  producto    Producto  @relation(fields: [productoId], references: [id])

  // La llave primaria es la combinación de ambos IDs
  @@id([promocionId, productoId])
}


