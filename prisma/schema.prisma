generator client {
  provider = "prisma-client"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // ✅ NO url here - now configured in prisma.config.ts
}

// Example User model for testing
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Producto {
  id          Int      @id @default(autoincrement()) @map("id_producto")
  nombre      String   @map("nombre_producto")
  codigoBarra String?  @map("codigo_barra")
  tipo        String?  @map("tipo_producto")
  proveedor   String?  @map("codigo_proveedor")
  stock       Int      @default(0) @map("stock_inicial")
  precio      Decimal  @default(0.00) @db.Decimal(10, 2) @map("precio_unitario")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("productos")
}
